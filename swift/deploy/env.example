# Discord Agent Bridge — deploy env.
# install.sh copies this to ~/.dab/env (chmod 0600) when it is missing.
# Secrets live ONLY here (0600). NEVER in the launchd plist (0644 = world-readable).

# Required: Discord gateway bot token (DISCORD_TOKEN also accepted).
DISCORD_BOT_TOKEN=

# Optional: Claude/Codex/Grok session working directory (default: home).
DAB_CWD=

# Optional: permission mode. bypassPermissions (default) skips the tool-permission
# UI — trusted envs only. Use "default" when a permission UI is available.
DAB_PERM_MODE=

# Optional: seconds to wait for a turn result before giving up (default 120).
DAB_TURN_TIMEOUT_SEC=

# Optional: dev guild id for instant per-guild slash registration (else global, ~1h).
DAB_DEV_GUILD_ID=

# PATH hint: launchd starts children with a minimal PATH. run.sh prepends
#   /opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$HOME/.grok/bin:$HOME/.cargo/bin
# before the inherited PATH. If node / codex / grok live elsewhere (e.g. nvm, a custom
# npm prefix), add that bin dir to run.sh's PATH export or export PATH here.
